# =============================================================================
# MLOps Pipeline - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_secret
POSTGRES_PORT=5432
# Requires custom init script (scripts/create-multiple-databases.sh)
POSTGRES_MULTIPLE_DATABASES=mlflow,prefect

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# MLflow
# -----------------------------------------------------------------------------
MLFLOW_PORT=5000

# -----------------------------------------------------------------------------
# Prefect
# -----------------------------------------------------------------------------
PREFECT_PORT=4200

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
