# =============================================================================
# MLOps Pipeline - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_secret
POSTGRES_PORT=5432
# CRITICAL: This variable has no effect without scripts/create-multiple-databases.sh
# mounted into the PostgreSQL container. Without it, only the default DB is created
# and MLflow/Prefect will fail to connect. See docs/layer-1-infrastructure.md.
POSTGRES_MULTIPLE_DATABASES=mlflow,prefect

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# MLflow
# -----------------------------------------------------------------------------
MLFLOW_PORT=5000

# -----------------------------------------------------------------------------
# Prefect
# -----------------------------------------------------------------------------
PREFECT_PORT=4200

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Inference API (Phase 5)
# -----------------------------------------------------------------------------
API_PORT=8000
SERVING_MODEL_NAME=cv-classifier
SERVING_MODEL_VERSION=latest
SERVING_DEVICE=auto
SERVING_IMAGE_SIZE=224
# SERVING_CLASS_NAMES=cat,dog,bird  # Optional: comma-separated class names
GUNICORN_WORKERS=2

# -----------------------------------------------------------------------------
# Nginx (Phase 5)
# -----------------------------------------------------------------------------
NGINX_PORT=80

# -----------------------------------------------------------------------------
# Monitoring (Phase 6)
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PUSHGATEWAY_PORT=9091
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Drift detection (DriftConfig, DRIFT_ prefix)
DRIFT_S3_ACCESS_KEY=${MINIO_ROOT_USER}
DRIFT_S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
