# =============================================================================
# Data Flywheel - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_secret
POSTGRES_PORT=5432
# CRITICAL: This variable has no effect without scripts/create-multiple-databases.sh
# mounted into the PostgreSQL container. Without it, only the default DB is created
# and MLflow/Prefect will fail to connect. See docs/layer-1-infrastructure.md.
POSTGRES_MULTIPLE_DATABASES=mlflow,prefect,labelstudio

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# MLflow
# -----------------------------------------------------------------------------
MLFLOW_PORT=5000

# -----------------------------------------------------------------------------
# Prefect
# -----------------------------------------------------------------------------
PREFECT_PORT=4200
PREFECT_API_URL=http://prefect-server:4200/api

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# -----------------------------------------------------------------------------
# Inference API (Phase 5)
# -----------------------------------------------------------------------------
API_PORT=8000
SERVING_MODEL_NAME=cv-classifier
SERVING_MODEL_VERSION=latest
SERVING_DEVICE=auto
SERVING_IMAGE_SIZE=224
# SERVING_CLASS_NAMES=cat,dog,bird  # Optional: comma-separated class names
GUNICORN_WORKERS=2

# -----------------------------------------------------------------------------
# Nginx (Phase 5)
# -----------------------------------------------------------------------------
NGINX_PORT=80

# Admin API security
ADMIN_API_KEY=  # Set a strong secret for /admin/ endpoints

# -----------------------------------------------------------------------------
# Monitoring (Phase 6)
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PUSHGATEWAY_PORT=9091
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Drift detection (DriftConfig, DRIFT_ prefix)
DRIFT_S3_ACCESS_KEY=${MINIO_ROOT_USER}
DRIFT_S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# -----------------------------------------------------------------------------
# Grafana alerting (Phase E-3)
# -----------------------------------------------------------------------------
# Multiple channels fan out in parallel per alert, so a single integration
# outage does not silence alerts. IMPORTANT: Grafana's provisioning validator
# rejects empty URLs / keys at startup, and because default-multi stacks
# three receivers into one contact point, a single empty value can fail the
# entire contact point — dropping ALL alerts. The sentinel defaults below are
# syntactically valid but guaranteed-undeliverable placeholders (e.g.
# ``.invalid`` TLD per RFC 2606) so Grafana provisioning always succeeds.
# Override any channel you want to actually use with real credentials.

# Email via SMTP — leave disabled if no outbound SMTP relay is available.
# If you enable SMTP, override GRAFANA_SMTP_FROM_ADDRESS with a sender your
# relay will accept (SPF/DMARC on made-up domains often fails silently).
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
GRAFANA_SMTP_FROM_ADDRESS=alerts@data-flywheel.local
GRAFANA_SMTP_FROM_NAME=Data Flywheel Alerts
GRAFANA_SMTP_SKIP_VERIFY=false
# Comma-separated recipients. Sentinel ``alerts@localhost`` keeps the email
# integration valid at provisioning time without delivering anywhere.
GRAFANA_ALERT_EMAIL_ADDRESSES=alerts@localhost

# Slack incoming webhook (also used for critical-escalation). Override with
# your real ``https://hooks.slack.com/services/...`` URL to enable.
GRAFANA_SLACK_WEBHOOK_URL=https://hooks.slack.invalid/disabled

# Generic webhook — Teams/Discord/in-house sink/Prefect notification block.
GRAFANA_GENERIC_WEBHOOK_URL=https://webhook.invalid/disabled

# PagerDuty Events API v2 integration key (only used by severity=critical).
# Non-empty string keeps the integration valid; ``disabled`` will produce a
# per-fire API rejection, which Grafana isolates from the other receivers.
GRAFANA_PAGERDUTY_INTEGRATION_KEY=disabled

# -----------------------------------------------------------------------------
# Active Learning (Phase A)
# -----------------------------------------------------------------------------
# Confidence routing thresholds
AL_AUTO_ACCUMULATE_THRESHOLD=0.95
AL_UNCERTAINTY_THRESHOLD=0.5

# Auto-accumulator settings
AL_ACCUMULATION_BUFFER_SIZE=500
AL_MAX_PSEUDO_LABEL_RATIO=0.3
AL_ACCUMULATION_BUCKET=active-learning
AL_ACCUMULATION_PREFIX=accumulated/
AL_S3_ENDPOINT=http://minio:9000

# Label Studio
AL_LABEL_STUDIO_URL=http://label-studio:8080
AL_LABEL_STUDIO_API_KEY=  # Set after Label Studio initial setup
AL_LABEL_STUDIO_PROJECT_ID=1
AL_WEBHOOK_CALLBACK_URL=http://api:8000/webhooks/label-studio
AL_WEBHOOK_SECRET=  # HMAC secret for Label Studio webhook signature verification
LABEL_STUDIO_PORT=8081

# -----------------------------------------------------------------------------
# Continuous Training - Phase B
# -----------------------------------------------------------------------------
# Data integration
CT_MERGED_DATA_DIR=data/merged
CT_TRAIN_VAL_SPLIT=0.8

# Retrain trigger thresholds
CT_MIN_ANNOTATION_COUNT=50
CT_MIN_ACCUMULATED_SAMPLES=100

# G2: Training quality gate
CT_MIN_VAL_ACCURACY=0.7
CT_MAX_OVERFIT_GAP=0.15

# G3: Champion gate
CT_CHAMPION_METRIC=best_val_accuracy
CT_CHAMPION_MARGIN=0.0

# Round tracking
CT_ROUND_STATE_BUCKET=active-learning
CT_ROUND_STATE_KEY=rounds/round_state.json

# S3 connection (AWS_* vars reference MinIO credentials for local S3-compatible access)
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
CT_S3_ENDPOINT=http://minio:9000
CT_S3_ACCESS_KEY=${AWS_ACCESS_KEY_ID}
CT_S3_SECRET_KEY=${AWS_SECRET_ACCESS_KEY}

# Prefect deployment name (used by event triggers)
CT_DEPLOYMENT_NAME=continuous-training/continuous-training-deployment

# MLflow
CT_MLFLOW_TRACKING_URI=http://mlflow:5000
CT_REGISTERED_MODEL_NAME=cv-classifier

# Label Studio (for data integration)
CT_LABEL_STUDIO_URL=http://label-studio:8080
CT_LABEL_STUDIO_API_KEY=  # Set after Label Studio initial setup
CT_LABEL_STUDIO_PROJECT_ID=1

# Label Studio admin seeding (iter 5 — scripts/seed_label_studio_project.py).
# The seed script logs in with these credentials (or signs up on first run),
# creates a minimal project, and prints CT_LABEL_STUDIO_API_KEY + PROJECT_ID
# to stdout so operators can source them back into their environment:
#     source <(uv run python scripts/seed_label_studio_project.py)
LABEL_STUDIO_USERNAME=admin@localhost
LABEL_STUDIO_PASSWORD=admin1234
AL_LABEL_STUDIO_API_KEY=  # set from seed script stdout
AL_LABEL_STUDIO_PROJECT_ID=1

# Dev-only: lower the 50-annotation threshold in ContinuousTrainingConfig so
# the webhook happy-path E2E can fire run_deployment against a minimally
# seeded Label Studio project (1 task + 1 annotation from the seed script).
# Must be >= 1 (Pydantic ge=1) — production should leave unset (defaults 50).
CT_MIN_ANNOTATION_COUNT=1
